# ============================================================
# Section 1: Project-specific files
# ============================================================
# This repo is used as a live dogfood instance, so per-project
# task guides, memory contents, and planning docs are tracked
# in git (not treated as framework-distribution-only content).

# Scratchpad
task.txt

# ============================================================
# Section 2: OS / editor noise
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# Section 3: Python artifacts
# ============================================================
__pycache__/
*.pyc
*.pyo

# ============================================================
# Section 4: Shell / test artifacts
# ============================================================
# Temp dirs that shell scripts may create during testing
tmp/
.tmp/
*.tmp

# ============================================================
# Section 5: Generated HTML reports (local-only, never commit)
# ============================================================
# Exception: the Token Audit Log (DDR-0001) must survive across worktrees/spawns via git,
# unlike ephemeral HTML reports — so it is tracked despite the reports/ blanket ignore.
# (Excluding directory contents with reports/* rather than reports/ itself is required for
# the negation below to take effect — git won't descend into a fully-excluded directory.)
reports/*
!reports/token-audit_*.md

# ============================================================
# Section 6: Hook runtime state (step counters, event traces)
# ============================================================
.claude/hooks/.state/
memory/event-trace/
